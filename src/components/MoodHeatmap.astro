---
import { readMoods, calculateStreak, formatDate } from "~/utils/mood";

const moods = readMoods();
const moodMap = new Map<string, number>();
for (const entry of moods) {
  moodMap.set(entry.date, entry.mood);
}

const today = new Date();
today.setHours(0, 0, 0, 0);
const oneYearAgo = new Date(today);
oneYearAgo.setFullYear(oneYearAgo.getFullYear() - 1);

const startDate = new Date(oneYearAgo);
const dayOfWeek = startDate.getDay();
startDate.setDate(startDate.getDate() - dayOfWeek);

interface Cell {
  date: string;
  level: number;
  mood: number | null;
}

const cells: Cell[] = [];
const cursor = new Date(startDate);
while (cursor <= today) {
  const dateStr = formatDate(cursor);
  const mood = moodMap.get(dateStr) ?? null;
  cells.push({ date: dateStr, level: mood ?? 0, mood });
  cursor.setDate(cursor.getDate() + 1);
}

const weeks: Cell[][] = [];
for (let i = 0; i < cells.length; i += 7) {
  weeks.push(cells.slice(i, i + 7));
}

const MONTH_NAMES = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];

interface MonthLabel { weekIndex: number; label: string; }

const monthLabels: MonthLabel[] = [];
weeks.forEach((week, weekIndex) => {
  const d = new Date(week[0].date);
  const dayOfMonth = d.getDate();
  if (weekIndex === 0 || (dayOfMonth >= 1 && dayOfMonth <= 7)) {
    const label = MONTH_NAMES[d.getMonth()];
    const prev = monthLabels[monthLabels.length - 1];
    if (!prev || prev.label !== label) {
      monthLabels.push({ weekIndex, label });
    }
  }
});

const filteredMonthLabels = monthLabels.filter(({ weekIndex }, index, labels) => {
  const minWeeks = 3;
  if (index === 0) return labels[1] && labels[1].weekIndex - weekIndex >= minWeeks;
  if (index === labels.length - 1) return weeks.length - weekIndex >= minWeeks;
  return true;
});

const colorScale = [
  "#1f2a40",
  "#233a30",
  "#2b553d",
  "#36754c",
  "#46995d",
  "#4ade80",
];

const blockSize = 12;
const blockMargin = 4;
const blockRadius = 2;
const fontSize = 14;
const labelHeight = fontSize + 8;
const width = weeks.length * (blockSize + blockMargin) - blockMargin;
const height = labelHeight + (blockSize + blockMargin) * 7 - blockMargin;
const pad = 4;
const svgWidth = width + pad * 2;
const svgHeight = height + pad * 2;

function getMoodLabel(mood: number): string {
  const labels = ["", "\u5F88\u5DEE", "\u4E0D\u592A\u597D", "\u4E00\u822C", "\u8FD8\u884C", "\u6781\u597D"];
  return labels[mood] || "";
}

const totalDays = moods.length;
const currentStreak = calculateStreak(moods);
---

<article class="mood-heatmap w-max max-w-full flex flex-col gap-2 text-sm">
  <div class="max-w-full overflow-x-auto pt-0.5" style="scrollbar-gutter: stable;">
    <svg
      class="block visible"
      width={svgWidth} height={svgHeight} viewBox={`${-pad} ${-pad} ${svgWidth} ${svgHeight}`}
    >
      <g>
        {filteredMonthLabels.map(({ label, weekIndex }) => (
          <text
            x={(weeks.length - 1 - weekIndex) * (blockSize + blockMargin)}
            y={0}
            dominant-baseline="hanging"
            fill="currentColor"
          >
            {label}
          </text>
        ))}
      </g>
      {[...weeks].reverse().map((week, reverseWeekIndex) => (
        <g transform={`translate(${(blockSize + blockMargin) * reverseWeekIndex}, 0)`}>
          {week.map((cell, dayIndex) => (
            <g class="mood-cell">
              <title>
                {cell.date}{cell.mood !== null ? " \u00B7 " + getMoodLabel(cell.mood) : " \u00B7 \u672A\u8BB0\u5F55"}
              </title>
              <rect
                class="stroke-foreground/10 mood-rect"
                x={0}
                y={labelHeight + (blockSize + blockMargin) * dayIndex}
                width={blockSize}
                height={blockSize}
                rx={blockRadius}
                ry={blockRadius}
                fill={colorScale[cell.level]}
                data-date={cell.date}
                data-level={cell.level}
              />
            </g>
          ))}
        </g>
      ))}
    </svg>
  </div>
  <footer class="flex flex-col sm:flex-row sm:justify-between gap-x-1 gap-y-2">
    <div>
      \u603B\u8BA1 <strong>{totalDays}</strong> \u5929\u8BB0\u5F55 \u00B7 \u8FDE\u7EED <strong>{currentStreak}</strong> \u5929
    </div>
    <div class="flex items-center gap-[3px]">
      <span class="mr-1.5">\u5DEE</span>
      {colorScale.slice(1).map((color) => (
        <svg width={blockSize} height={blockSize}>
          <rect class="stroke-foreground/10" width={blockSize} height={blockSize} fill={color} rx={blockRadius} ry={blockRadius} />
        </svg>
      ))}
      <span class="ml-1.5">\u6781\u597D</span>
    </div>
  </footer>
</article>

<style>
  .mood-cell .mood-rect {
    transform-origin: center;
    transform-box: fill-box;
    transition: transform 0.15s ease, stroke 0.15s ease;
  }
  .mood-cell:hover .mood-rect {
    transform: scale(1.35);
    stroke: var(--theme-accent);
    stroke-width: 1.5;
  }
</style>